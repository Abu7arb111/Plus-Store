<dict>
	<key>PayloadContent</key>
	<dict>
		<key>URL</key>
		<string>https://your-domain.com/api/register-device</string>
		<key>DeviceAttributes</key>
		<array>
			<string>UDID</string>
			<string>IMEI</string>
			<string>ICCID</string>
			<string>VERSION</string>
			<string>PRODUCT</string>
