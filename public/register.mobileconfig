	<key>PayloadIdentifier</key>
	<string>com.plusstore.registration</string>
	<key>PayloadOrganization</key>
	<string>Plus Store Inc.</string>
	<key>PayloadType</key>
	<string>Profile Service</string>
	<key>PayloadUUID</key>
	<string>7A2A15B0-DE86-49FA-8E7B-A2A15B0DE860</string>
	<key>PayloadVersion</key>
	<integer>1</integer>
</dict>
